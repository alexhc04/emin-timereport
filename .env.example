# .env.example - Copia este archivo como ".env" para desarrollo local
# NUNCA subas el archivo .env real a GitHub

# Clave secreta para las sesiones (cambia esto por una cadena aleatoria larga)
SECRET_KEY=cambia-esto-por-algo-muy-secreto-2024

# URL de base de datos
# Para desarrollo local (SQLite automático si no se define)
# DATABASE_URL=sqlite:///emin_local.db

# Para producción con Supabase PostgreSQL:
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_base_datos
